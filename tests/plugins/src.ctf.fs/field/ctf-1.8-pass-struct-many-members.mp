---
struct {
  u8      m01;
  i16le   m02;
  u32le   m03;
  i64le   m04;
  flt32le m05;
  flt64le m06;
  nt_str  m07;
  u8      m08;
  i16le   m09;
  u32le   m10;
}

---
$1            # `m01`
[-2:16le]     # `m02`
[3:32le]      # `m03`
[-4:64le]     # `m04`
[5.5:32le]    # `m05`
[6.25:64le]   # `m06`
"hello\0"     # `m07`
$8            # `m08`
[-9:16le]     # `m09`
[10:32le]     # `m10`

---
m01: 1
m02: -2
m03: 3
m04: -4
m05: 5.500000
m06: 6.250000
m07: "hello"
m08: 8
m09: -9
m10: 10
