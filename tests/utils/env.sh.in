# Source this file to access an environment to run `pytest` directly
# with the needed environment variables.
#
# For an out-of-tree build, use the `bt-pytest` function.
#
# Compatible with Bash and Zsh.
#
# Path separators are always `:` (Unix style) because, when running from
# an MSYS2 shell, the automatic path conversion to Windows style
# (including converting `:` to `;`) occurs when spawning a native
# Windows program such as a UCRT64 Python interpreter (to run pytest).

# Prints the OS type.
_bt_os_type() {
    local os_type

    os_type=$(uname -s)

    case $os_type in
    MINGW*)
        os_type=mingw
        ;;
    Darwin)
        os_type=darwin
        ;;
    Linux)
        os_type=linux
        ;;
    CYGWIN*)
        os_type=cygwin
        ;;
    *)
        os_type=unsupported
        ;;
    esac

    echo -n "$os_type"
}


# Sets the library search path based on OS type.
_bt_set_lib_search_path() {
    local -r os_type=$(_bt_os_type)
    local -r main_lib_path=$BT_TESTS_BUILDDIR/../src/lib/.libs

    if [[ $os_type == mingw || $os_type == cygwin ]]; then
        export PATH=$main_lib_path${PATH:+:}${PATH:-}
    elif [[ $os_type == darwin ]]; then
        export DYLD_LIBRARY_PATH=$main_lib_path${DYLD_LIBRARY_PATH:+:}${DYLD_LIBRARY_PATH:-}
    else
        export LD_LIBRARY_PATH=$main_lib_path${LD_LIBRARY_PATH:+:}${LD_LIBRARY_PATH:-}
    fi
}

# Sets `PYTHONHOME` for Windows (MinGW).
_bt_set_pythonhome() {
    if [[ -n ${ZSH_VERSION:-} ]]; then
        setopt localoptions shwordsplit;
    fi

    if [[ $(_bt_os_type) == mingw ]]; then
        PYTHONHOME=$($BT_TESTS_PYTHON_CONFIG_BIN --prefix)
        export PYTHONHOME
    fi
}

# Sets up AddressSanitizer environment if enabled.
_bt_set_asan() {
    # Set from build configuration if not already set
    if [[ -z ${BT_TESTS_ENABLE_ASAN:-} ]]; then
        local BT_TESTS_ENABLE_ASAN='@ENABLE_ASAN@'
    fi

    if [[ -z ${BT_TESTS_CC_BIN:-} ]]; then
        local BT_TESTS_CC_BIN='@CC@'
    fi

    if [[ -z ${BT_TESTS_GREP_BIN:-} ]]; then
        local BT_TESTS_GREP_BIN='@GREP@'
    fi

    # If AddressSanitizer is used, we must preload `libasan.so` so that
    # libasan doesn't complain about not being the first loaded library.
    #
    # Python and sed (executed as part of the Libtool wrapper) produce
    # some leaks, so we must unfortunately disable leak detection.
    #
    # Append it to existing `ASAN_OPTIONS` variable, such that we
    # override the user's value if it contains `detect_leaks=1`.
    if [[ -n ${ZSH_VERSION:-} ]]; then
        setopt localoptions shwordsplit;
    fi

    if [[ ${BT_TESTS_ENABLE_ASAN:-} == 1 ]]; then
        if $BT_TESTS_CC_BIN --version | head -n 1 | $BT_TESTS_GREP_BIN -qi '^gcc'; then
            local -r lib_asan=$($BT_TESTS_CC_BIN -print-file-name=libasan.so)
            local -r lib_stdcxx=$($BT_TESTS_CC_BIN -print-file-name=libstdc++.so)
            export LD_PRELOAD=$lib_asan:$lib_stdcxx${LD_PRELOAD:+:}${LD_PRELOAD:-}
        fi

        export ASAN_OPTIONS=${ASAN_OPTIONS:-}${ASAN_OPTIONS:+,}detect_leaks=0
    fi
}

# Sets `PYTHONPATH` for in-tree pytest if enabled.
_bt_set_vendor_pytest() {
    if ((! @HAVE_VENDOR_PYTEST@)); then
        return
    fi

    local pytest_dir

    if ((_bt_py_minor_version >= 7)); then
        pytest_dir=pytest-7.4.3
    else
        pytest_dir=pytest-6.1.2
    fi

    export PYTHONPATH=$BT_TESTS_SRCDIR/utils/python/vendor/$pytest_dir${PYTHONPATH:+:}${PYTHONPATH:-}
}

# Sets `PYTHONPATH` so that testing utilities and the `bt2` package
# are available.
_bt_set_pythonpath() {
    # Add to the module search path:
    #
    # • `utils/python` and `utils/python/vendor` (contain utilities).
    # • The `bt2` package (Python bindings).
    local -r src_utils_python_dir=$BT_TESTS_SRCDIR/utils/python
    local pythonpath=$src_utils_python_dir:$src_utils_python_dir/vendor:$BT_TESTS_BUILDDIR/../src/bindings/python/bt2/build/build_lib

    # Add a local directory containing a `typing.py` to the module
    # search path for Python 3.5 which only offers a partial
    # `typing` module.
    if ((_bt_py_minor_version == 5)); then
        pythonpath=$pythonpath:$src_utils_python_dir/vendor/typing
    fi

    export PYTHONPATH=$pythonpath${PYTHONPATH:+:}${PYTHONPATH:-}
}

# Sets `_bt_py_minor_version` to Python's `sys.version_info.minor`.
_bt_set_py_minor_version() {
    if [[ -n ${ZSH_VERSION:-} ]]; then
        setopt localoptions shwordsplit;
    fi

    _bt_py_minor_version=$($BT_TESTS_PYTHON_BIN -c 'import sys; print(sys.version_info.minor, end="")')
}

# Sets plugin-related environment variables so that common utility
# plugins as well as compiled, shared object plugins are available
# to libbabeltrace2.
_bt_set_babeltrace_plugin_path() {
    # Set `BABELTRACE_PLUGIN_PATH`
    local -r plugins_path=$BT_TESTS_BUILDDIR/../src/plugins
    export BABELTRACE_PLUGIN_PATH=$BT_TESTS_SRCDIR/utils/python:$plugins_path/ctf:$plugins_path/utils:$plugins_path/text:$plugins_path/lttng-utils

    # Set `LIBBABELTRACE2_PLUGIN_PROVIDER_DIR`
    export LIBBABELTRACE2_PLUGIN_PROVIDER_DIR=$BT_TESTS_BUILDDIR/../src/python-plugin-provider/.libs
}

# Setup
{
    # Set from build configuration if not already set
    if [[ -z ${BT_TESTS_SRCDIR:-} ]]; then
        export BT_TESTS_SRCDIR='@abs_top_srcdir@/tests'
    fi

    if [[ -z ${BT_TESTS_BUILDDIR:-} ]]; then
        export BT_TESTS_BUILDDIR='@abs_top_builddir@/tests'
    fi

    if [[ -z ${BT_TESTS_PYTHON_BIN:-} ]]; then
        export BT_TESTS_PYTHON_BIN='@PYTHON@'
    fi

    if [[ -z ${BT_TESTS_PYTHON_CONFIG_BIN:-} ]]; then
        export BT_TESTS_PYTHON_CONFIG_BIN='@PYTHON_CONFIG@'
    fi

    # Set `_bt_py_minor_version` variable
    _bt_set_py_minor_version

    # Set the library search path based on current OS
    _bt_set_lib_search_path

    # Set `PYTHONHOME` for Windows (MinGW)
    _bt_set_pythonhome

    # Set up AddressSanitizer environment if enabled
    _bt_set_asan

    # Set up in-tree pytest if enabled
    _bt_set_vendor_pytest

    # Set `PYTHONPATH` for testing utilities and `bt2` package
    _bt_set_pythonpath

    # Set plugin-related environment variables
    _bt_set_babeltrace_plugin_path
}

# Clean up the local functions and variables
unset -f _bt_os_type
unset -f _bt_set_lib_search_path
unset -f _bt_set_pythonhome
unset -f _bt_set_asan
unset -f _bt_set_vendor_pytest
unset -f _bt_set_py_minor_version
unset -f _bt_set_pythonpath
unset -f _bt_set_babeltrace_plugin_path
unset _bt_py_minor_version

# Wraps `pytest` with options that are suitable for both in-tree and
# out-of-tree builds.
bt-pytest() {
    if [[ -n ${ZSH_VERSION:-} ]]; then
        setopt localoptions shwordsplit;
    fi

    $BT_TESTS_PYTHON_BIN -m pytest \
        -o cache_dir="${BT_TESTS_BUILDDIR}/.pytest_cache" "$@"
}
