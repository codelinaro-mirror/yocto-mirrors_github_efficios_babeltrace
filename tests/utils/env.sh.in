# Source this file to access an environment to execute `pytest` directly
# with the needed environment variables.
#
# For an out-of-tree build, use the `bt-pytest` function.
#
# Also offers the `BT_TESTS_PYTHON_LD_PRELOAD` parameter and the
# `bt-python`/`bt-python-env` functions.
#
# Use `bt-deactivate` to undo all environment changes, or simply
# source the `env.sh` file of another build (it deactivates
# automatically).
#
# Compatible with Bash and Zsh.
#
# Path separators are always `:` (Unix style) because, when running from
# an MSYS2 shell, the automatic path conversion to Windows style
# (including converting `:` to `;`) occurs when spawning a native
# Windows program such as a UCRT64 Python interpreter (to
# execute pytest).

# Prints the OS type.
_bt_tests_os_type() {
    local os_type

    os_type=$(uname -s)

    case $os_type in
    MINGW*)
        os_type=mingw
        ;;
    Darwin)
        os_type=darwin
        ;;
    Linux)
        os_type=linux
        ;;
    CYGWIN*)
        os_type=cygwin
        ;;
    *)
        os_type=unsupported
        ;;
    esac

    echo -n "$os_type"
}


# Sets the library search path based on OS type.
_bt_tests_set_lib_search_path() {
    local -r os_type=$(_bt_tests_os_type)
    local -r main_lib_path=$BT_TESTS_BUILDDIR/../src/lib/.libs

    if [[ $os_type == mingw || $os_type == cygwin ]]; then
        export PATH=$main_lib_path${PATH:+:}${PATH:-}
    elif [[ $os_type == darwin ]]; then
        export DYLD_LIBRARY_PATH=$main_lib_path${DYLD_LIBRARY_PATH:+:}${DYLD_LIBRARY_PATH:-}
    else
        export LD_LIBRARY_PATH=$main_lib_path${LD_LIBRARY_PATH:+:}${LD_LIBRARY_PATH:-}
    fi
}

# Sets `PYTHONHOME` for Windows (MinGW).
_bt_tests_set_pythonhome() {
    if [[ -n ${ZSH_VERSION:-} ]]; then
        setopt localoptions shwordsplit;
    fi

    if [[ $(_bt_tests_os_type) == mingw ]]; then
        PYTHONHOME=$($BT_TESTS_PYTHON_CONFIG_BIN --prefix)
        export PYTHONHOME
    fi
}

# Determines the `LD_PRELOAD` value required for `bt-python-env`.
_bt_tests_set_python_ld_preload() {
    # Set from build configuration if not already set
    if [[ -z ${BT_TESTS_ENABLE_ASAN:-} ]]; then
        local BT_TESTS_ENABLE_ASAN='@ENABLE_ASAN@'
    fi

    if [[ -z ${BT_TESTS_ENABLE_UBSAN:-} ]]; then
        local BT_TESTS_ENABLE_UBSAN='@ENABLE_UBSAN@'
    fi

    # If AddressSanitizer is used, we must preload `libasan.so` so that
    # libasan doesn't complain about not being the first loaded library.
    #
    # Likewise with UndefinedBehaviorSanitizer and `libubsan.so`,
    # otherwise we may get errors like
    #
    #     undefined symbol: __ubsan_vptr_type_cache
    #
    # when trying to load shared libraries or plugins.
    #
    # The `bt-python-env` function uses the `_bt_tests_asan_enabled` and
    # `BT_TESTS_PYTHON_LD_PRELOAD` parameters.
    _bt_tests_asan_enabled=0

    if [[ ${BT_TESTS_ENABLE_ASAN:-} == 1 || ${BT_TESTS_ENABLE_UBSAN:-} == 1 ]]; then
        if [[ -n ${ZSH_VERSION:-} ]]; then
            setopt localoptions shwordsplit;
        fi

        # Set from build configuration if not already set
        if [[ -z ${BT_TESTS_CC_BIN:-} ]]; then
            local BT_TESTS_CC_BIN='@CC@'
        fi

        if [[ -z ${BT_TESTS_GREP_BIN:-} ]]; then
            local BT_TESTS_GREP_BIN='@GREP@'
        fi

        if $BT_TESTS_CC_BIN --version | head -n 1 | $BT_TESTS_GREP_BIN -qi '^gcc'; then
            if [[ ${BT_TESTS_ENABLE_ASAN:-} == 1 ]]; then
                local -r lib_asan=$($BT_TESTS_CC_BIN -print-file-name=libasan.so)
                local -r lib_stdcxx=$($BT_TESTS_CC_BIN -print-file-name=libstdc++.so)
                BT_TESTS_PYTHON_LD_PRELOAD=$lib_asan:$lib_stdcxx

                # Make `bt-python-env` know that ASan is enabled
                _bt_tests_asan_enabled=1
            fi

            if [[ ${BT_TESTS_ENABLE_UBSAN:-} == 1 ]]; then
                local -r lib_ubsan=$($BT_TESTS_CC_BIN -print-file-name=libubsan.so)
                BT_TESTS_PYTHON_LD_PRELOAD=${BT_TESTS_PYTHON_LD_PRELOAD:+$BT_TESTS_PYTHON_LD_PRELOAD:}$lib_ubsan
            fi
        fi
    fi
}

# Sets `PYTHONPATH` for in-tree pytest if enabled.
_bt_tests_set_vendor_pytest() {
    if ((! @HAVE_VENDOR_PYTEST@)); then
        return
    fi

    local pytest_dir

    if ((_bt_tests_py_minor_version >= 7)); then
        pytest_dir=pytest-7.4.3
    else
        pytest_dir=pytest-7.0.1
    fi

    export PYTHONPATH=$BT_TESTS_SRCDIR/utils/python/vendor/$pytest_dir${PYTHONPATH:+:}${PYTHONPATH:-}
}

# Sets `PYTHONPATH` so that testing utilities and the `bt2` package
# are available.
_bt_tests_set_pythonpath() {
    # Add to the module search path:
    #
    # â€˘ `utils/python` and `utils/python/vendor` (contain utilities).
    # â€˘ The `bt2` package (Python bindings).
    local -r src_utils_python_dir=$BT_TESTS_SRCDIR/utils/python
    local pythonpath=$src_utils_python_dir:$src_utils_python_dir/vendor:$BT_TESTS_BUILDDIR/../src/bindings/python/bt2/build/build_lib

    export PYTHONPATH=$pythonpath${PYTHONPATH:+:}${PYTHONPATH:-}
}

# Sets `_bt_tests_py_minor_version` to Python's `sys.version_info.minor`.
_bt_tests_set_py_minor_version() {
    if [[ -n ${ZSH_VERSION:-} ]]; then
        setopt localoptions shwordsplit;
    fi

    _bt_tests_py_minor_version=$($BT_TESTS_PYTHON_BIN -c 'import sys; print(sys.version_info.minor, end="")')
}

# Sets plugin-related environment variables so that common utility
# plugins as well as compiled, shared object plugins are available
# to libbabeltrace2.
_bt_tests_set_babeltrace_plugin_path() {
    # Set `BABELTRACE_PLUGIN_PATH`
    local -r plugins_path=$BT_TESTS_BUILDDIR/../src/plugins
    export BABELTRACE_PLUGIN_PATH=$BT_TESTS_SRCDIR/utils/python:$plugins_path/ctf:$plugins_path/utils:$plugins_path/text:$plugins_path/lttng-utils

    # Set `LIBBABELTRACE2_PLUGIN_PROVIDER_DIR`
    export LIBBABELTRACE2_PLUGIN_PROVIDER_DIR=$BT_TESTS_BUILDDIR/../src/python-plugin-provider/.libs
}

# Sets `_bt_tests_saved_param_names` to the list of parameters to
# save/restore and saves the current state of each one using
# `declare -p` so that `_bt_tests_restore_param` can restore it later.
#
# For each parameter named NAME, if it's set, this function sets the
# `_bt_tests_saved_NAME_decl` parameter to the full `declare -p` output
# (which captures the value, export state, and type). Otherwise, this
# function sets `_bt_tests_saved_NAME_decl` to an empty string.
_bt_tests_save_params() {
    _bt_tests_saved_param_names=(
        PATH
        LD_LIBRARY_PATH
        DYLD_LIBRARY_PATH
        PYTHONPATH
        PYTHONHOME
        BT_TESTS_SRCDIR
        BT_TESTS_BUILDDIR
        BT_TESTS_PYTHON_BIN
        BT_TESTS_PYTHON_CONFIG_BIN
        BT_TESTS_PYTHON_LD_PRELOAD
        BABELTRACE_PLUGIN_PATH
        LIBBABELTRACE2_PLUGIN_PROVIDER_DIR
    )

    local param_name

    for param_name in "${_bt_tests_saved_param_names[@]}"; do
        # `|| true` ensures that `declare -p` failing for a nonexistent
        # variable doesn't cause the shell to exit under `set -e`.
        # In that case, `_bt_tests_saved_${param_name}_decl` is set to
        # an empty string.
        eval "_bt_tests_saved_${param_name}_decl=\$(declare -p $param_name 2>/dev/null || true)"
    done
}

# Setup
{
    # If a previous `env.sh` file was sourced, deactivate it first so that
    # sourcing the `env.sh` file of another build fully overrides the
    # previous one.
    # shellcheck disable=SC2218
    type bt-deactivate &>/dev/null && bt-deactivate

    # Save the state of parameters that we'll modify, so that
    # `bt-deactivate` can restore them.
    _bt_tests_save_params

    # Set from build configuration if not already set
    if [[ -z ${BT_TESTS_SRCDIR:-} ]]; then
        export BT_TESTS_SRCDIR='@abs_top_srcdir@/tests'
    fi

    if [[ -z ${BT_TESTS_BUILDDIR:-} ]]; then
        export BT_TESTS_BUILDDIR='@abs_top_builddir@/tests'
    fi

    if [[ -z ${BT_TESTS_PYTHON_BIN:-} ]]; then
        export BT_TESTS_PYTHON_BIN='@PYTHON@'
    fi

    if [[ -z ${BT_TESTS_PYTHON_CONFIG_BIN:-} ]]; then
        export BT_TESTS_PYTHON_CONFIG_BIN='@PYTHON_CONFIG@'
    fi

    # Set `_bt_tests_py_minor_version` parameter
    _bt_tests_set_py_minor_version

    # Set the library search path based on current OS
    _bt_tests_set_lib_search_path

    # Set `PYTHONHOME` for Windows (MinGW)
    _bt_tests_set_pythonhome

    # Determine `LD_PRELOAD` settings for `bt-python-env`
    _bt_tests_set_python_ld_preload

    # Set up in-tree pytest if enabled
    _bt_tests_set_vendor_pytest

    # Set `PYTHONPATH` for testing utilities and `bt2` package
    _bt_tests_set_pythonpath

    # Set plugin-related environment variables
    _bt_tests_set_babeltrace_plugin_path
}

# Clean up the local functions and variables
unset -f _bt_tests_os_type
unset -f _bt_tests_set_lib_search_path
unset -f _bt_tests_set_pythonhome
unset -f _bt_tests_set_python_ld_preload
unset -f _bt_tests_set_vendor_pytest
unset -f _bt_tests_set_py_minor_version
unset -f _bt_tests_set_pythonpath
unset -f _bt_tests_set_babeltrace_plugin_path
unset -f _bt_tests_save_params
unset _bt_tests_py_minor_version

# Usage:
#
#     bt-python-env ARGS...
#
# Executes ARGS with the `LD_PRELOAD` and `ASAN_OPTIONS` environment
# variables needed for sanitizers (ASan/UBSan) to work correctly
# with Python.
bt-python-env() {
    if [[ -n ${ZSH_VERSION:-} ]]; then
        setopt localoptions shwordsplit;
    fi

    if [[ -n ${BT_TESTS_PYTHON_LD_PRELOAD:-} ]]; then
        local -x LD_PRELOAD=$BT_TESTS_PYTHON_LD_PRELOAD${LD_PRELOAD:+:}${LD_PRELOAD:-}

        if ((_bt_tests_asan_enabled)); then
            # Python and sed (executed as part of the Libtool wrapper)
            # produce some leaks, so we must unfortunately disable leak
            # detection.
            #
            # Append it to existing `ASAN_OPTIONS` environment variable,
            # such that we override the user's value if it contains
            # `detect_leaks=1`.
            local -x ASAN_OPTIONS=${ASAN_OPTIONS:-}${ASAN_OPTIONS:+,}detect_leaks=0
        fi
    fi

    "$@"
}

# Usage:
#
#     bt-python [ARGS...]
#
# Executes `bt-python-env` with the configured Python interpreter
# (`$BT_TESTS_PYTHON_BIN`), forwarding ARGS.
bt-python() {
    bt-python-env "$BT_TESTS_PYTHON_BIN" "$@"
}

# Usage:
#
#     bt-pytest [ARGS...]
#
# Wraps `pytest` with options that are suitable for both in-tree and
# out-of-tree builds, forwarding ARGS.
bt-pytest() {
    bt-python -m pytest -o cache_dir="${BT_TESTS_BUILDDIR}/.pytest_cache" "$@"
}

# Undoes all environment changes made by sourcing this script, restoring
# the shell to its previous state.
bt-deactivate() {
    # Restore all saved parameters to their original state
    local param_name
    local saved_decl_name
    local decl

    for param_name in "${_bt_tests_saved_param_names[@]}"; do
        saved_decl_name=_bt_tests_saved_${param_name}_decl
        eval "decl=\${$saved_decl_name:-}"

        # Unset the parameter first so that `declare -g`/`typeset -g`
        # starts from a clean state (otherwise pre-existing attributes
        # like the export flag would persist).
        unset -v "$param_name"

        if [[ -n $decl ]]; then
            # Add `-g` so that the declaration targets the global scope
            # (needed because this runs inside a function).
            #
            # Bash uses `declare` while Zsh uses `typeset`/`export`.
            if [[ $decl == declare\ * ]]; then
                decl="declare -g ${decl#declare }"
            elif [[ $decl == typeset\ * ]]; then
                decl="typeset -g ${decl#typeset }"
            elif [[ $decl == export\ * ]]; then
                decl="typeset -gx ${decl#export }"
            fi

            eval "$decl"
        fi

        unset "$saved_decl_name"
    done

    # Unset our specific functions and parameters
    unset _bt_tests_asan_enabled _bt_tests_saved_param_names
    unset -f bt-python-env bt-python bt-pytest bt-deactivate
}
